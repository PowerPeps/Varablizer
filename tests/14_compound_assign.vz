// Test 14 — Assignments composés
// Expected output:
//   15
//   10
//   30
//   6
//   1
//   7
//   5
//   4

b_8 int x = 10;
x += 5;  pf(x);   // 15
x -= 5;  pf(x);   // 10
x *= 3;  pf(x);   // 30
x /= 5;  pf(x);   // 6
x %= 5;  pf(x);   // 1

b_8 int y = 3;
y |= 4;  pf(y);   // 7  (0b011 | 0b100 = 0b111)
y &= 5;  pf(y);   // 5  (0b111 & 0b101 = 0b101)
y ^= 1;  pf(y);   // 4  (0b101 ^ 0b001 = 0b100)
