namespace demo.core
use io.console

// ==================================================
// Déclarations mémoire & types
// ==================================================

b_8   unsigned int<le> counter := 0;
y_4   signed   int<be> limit   := 10;
w_2   char              letter := 'A';
d_1   float             ratio  := 1;
q_1   raw               blob;

// alignement explicite
b_16 @16 unsigned int<le> alignedValue := 16;

// ==================================================
// Pointeurs & adresses
// ==================================================

b_8 int value := 5;
b_8 int* ptr  = &value;

// ==================================================
// Structure mémoire typée
// ==================================================

b_8 int {
    a : 10,
    b : 20,
    c : 30,
};

// ==================================================
// Chaînes
// ==================================================

b_8 char {
    s1 : "hello",
    s2 : 'x',
    s3 : `raw`,
};

// ==================================================
// Fonctions
// ==================================================

int function add(b_8 int x, b_8 int y) {
    return x + y;
}

int fn sub(b_8 int x, b_8 int y) {
    return x - y;
}

// ==================================================
// Classe
// ==================================================

class Engine {

    void mount() {
        pf("Engine mounted");
    }

    void boot() {
        pf("Engine booted");
    }

    void updated() {
        pf("Engine updated");
    }

    void exception() {
        pf("Engine exception");
    }
}

// ==================================================
// Objet
// ==================================================

objet app {
    ...
}

// ==================================================
// Lambda & opérateurs
// ==================================================

() => {
    pf("Simple lambda");
}

adder := { $1++; $2-- }>

result := [10, 5] ={$1++; $2--}> $1 + $2;

// ==================================================
// Pipeline
// ==================================================

f1() |> f2() |> f3()

// ==================================================
// Flow buffer
// ==================================================

stdin |{ b_8[256] @64 unsigned int<le> }> stdout

// ==================================================
// Builtins
// ==================================================

pf("Counter = ", counter);
p(counter);
dd(counter);
nop;

// ==================================================
// Boucles
// ==================================================

for (b_8 i := 0, i < limit, i++) {
    counter++;
}

for (b_8 i := 0, i < limit, i++) do
    pf(i);

do {
    counter--;
} while (counter > 0);

while (counter < limit) {
    counter++;
}

// pointeurs + incrément
while (*ptr++ = *ptr--)

// ==================================================
// Comparaisons & arithmétique
// ==================================================

if (counter >= limit) {
    pf("Done");
} else {
    pf("Running");
}
