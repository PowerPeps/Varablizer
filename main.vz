namespace ...
use ...

b_N  // bits
y_N  // octets
w_N  // words
d_N  // dwords
q_N  // qwords

[ b_N | y_N | w_N | d_N | q_N ] [ @align ] [ signed | unsigned ] [ int<le> | int<le> | float | char | raw ]

"A memory region may only be interpreted as a type whose size exactly matches the region size."

b_8 @8 unsigned int<le> = 16

b_8 int a 10;
b_8 int a = 10;
b_8 int a := 10;
b_8 int a : 10;
// Tout les opérateurs ci-dessus sont possible, ils n'ont actuellement aucunne différence.

b_8 int {
    a : 10,
    b : 10,
    c : 30,
};

b_8 char {
    a : "10",
    b : '10',
    c : `10`,
}; // Permet de définir plusieurs variable du même type à la suite, elle ce suivrons dans la mémoire.

b_8 int* b = &a
b_8 char* b = &a

pf(char a)
p(a)
nop;
dd(a)

for (b_8 i, i > 10, i++) {...};

for (b_8 i, i > 10, i++) do ...;

do {...} while (i > b_8 int 10);

while (*s++ = *t++)

while (i > b_8 int 10) {...};

while (i > b_8 int 10) do ...;

