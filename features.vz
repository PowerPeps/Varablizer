b_8 int[5] seq = [1, 2, 3, 4, 5];

// ==================================================
// 12. STRUCTURES MEMOIRE TYPEE
// ==================================================

b_8 int {
    field1 : 10,
    field2 : 20,
    field3 : 30
};

// ==================================================
// 13. STRINGS
// ==================================================

b_8 char str1 = "double quotes";
b_8 char str2 = 'single quotes';
b_8 char str3 = `backticks`;

// ==================================================
// 14. STRING INTERPOLATION
// ==================================================

b_8 int counter = 100;
b_8 char msg = "Value is ${counter}";

// ==================================================
// 15. FONCTION SIMPLE
// ==================================================

int function add(b_8 int x, b_8 int y) {
    return x + y;
}

// ==================================================
// 16. FONCTION AVEC FN
// ==================================================

int fn multiply(b_8 int x, b_8 int y) {
    return x * y;
}

// ==================================================
// 17. FONCTION SANS RETOUR
// ==================================================

void function printValue(b_8 int val) {
    pf("Value: ", val);
}

// ==================================================
// 18. APPEL DE FONCTION
// ==================================================

b_8 int result1 = add(10, 20);
b_8 int result2 = multiply(5, 6);
printValue(result1);

// ==================================================
// 19. BUILTINS
// ==================================================

pf("Hello");
p(counter);
dd(value);
nop;

// ==================================================
// 20. IF SIMPLE
// ==================================================

if (a > b) {
    a = 100;
}

// ==================================================
// 21. IF ELSE
// ==================================================

if (a > b) {
    a = 100;
} else {
    b = 200;
}

// ==================================================
// 22. TERNARY OPERATOR
// ==================================================

b_8 int max = (a > b) ? a : b;
b_8 int min = (a < b) ? a : b;

// ==================================================
// 23. ELVIS OPERATOR
// ==================================================

b_8 int* nullable = null;
b_8 int safe1 = nullable ?: 42;

// ==================================================
// 24. NULL COALESCING
// ==================================================

b_8 int safe2 = nullable ?? 100;

// ==================================================
// 25. WHILE SIMPLE
// ==================================================

while (counter > 0) {
    counter--;
}

// ==================================================
// 26. WHILE DO
// ==================================================

while (counter < 10) do counter++;

// ==================================================
// 27. DO WHILE
// ==================================================

do {
    counter++;
} while (counter < 20);

// ==================================================
// 28. FOR SIMPLE
// ==================================================

for (b_8 int i = 0, i < 10, i++) {
    pf(i);
}

// ==================================================
// 29. FOR DO
// ==================================================

for (b_8 int j = 0, j < 5, j++) do pf(j);

// ==================================================
// 30. BREAK & CONTINUE
// ==================================================

for (b_8 int k = 0, k < 10, k++) {
    if (k == 3) continue;
    if (k == 7) break;
    pf(k);
}

// ==================================================
// 31. TYPEOF
// ==================================================

if (typeof a == "int") {
    pf("a is int");
}

// ==================================================
// 32. INSTANCEOF
// ==================================================

if (value instanceof int) {
    pf("value is int instance");
}

