// ==================================================
// 1. VARIABLES & TYPES BASIQUES
// ==================================================

b_8 int a = 10;
b_8 int b = 20;
b_16 int c = 1000;
y_4 int d = 500;

b_8 unsigned int x = 255;
b_8 signed int y = -128;

float f = 3.14;
b_8 char ch = 'A';

// ==================================================
// 2. TYPES AVEC ENDIANNESS
// ==================================================

b_16 int<le> little = 0x1234;
b_16 int<be> big = 0x5678;

// ==================================================
// 3. STRING TYPE
// ==================================================

string<8> name = "hello";
string<16> unicode = "world";

// ==================================================
// 4. OPERATEURS ARITHMETIQUES
// ==================================================

b_8 int sum = a + b;
b_8 int diff = a - b;
b_8 int prod = a * b;
b_8 int quot = a / b;
b_8 int mod = a % b;

// ==================================================
// 5. OPERATEURS DE COMPARAISON
// ==================================================

b_8 int eq = (a == b);
b_8 int neq = (a != b);
b_8 int lt = (a < b);
b_8 int gt = (a > b);
b_8 int lte = (a <= b);
b_8 int gte = (a >= b);

// ==================================================
// 6. OPERATEURS BITWISE
// ==================================================

b_8 int and_op = a & b;
b_8 int or_op = a | b;
b_8 int xor_op = a ^ b;
b_8 int not_op = ~a;
b_8 int lshift = a << 2;
b_8 int rshift = a >> 1;

// ==================================================
// 7. INCREMENT / DECREMENT
// ==================================================

a++;
b--;
++a;
--b;

// ==================================================
// 8. ASSIGNMENTS COMPOSES
// ==================================================

a += 5;
b -= 3;
c *= 2;
d /= 4;
x &= 0xFF;
y |= 0x0F;

// ==================================================
// 9. POINTEURS
// ==================================================

b_8 int value = 42;
b_8 int* ptr = &value;
b_8 int deref = *ptr;

// ==================================================
// 10. TABLEAUX FIXES
// ==================================================

b_8 int[5] arr;
arr[0] = 1;
arr[1] = 2;
b_8 int first = arr[0];

// ==================================================
// 11. LITTERAUX ARRAY
// ==================================================

