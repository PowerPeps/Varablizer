// ==================================================
// 70. TOUT ENSEMBLE - EXEMPLE COMPLEXE
// ==================================================

class SmartBuffer {
    b_8 int* data;
    b_8 int size;

    void mount() {
        this.size = 1024;
        this.data = malloc(this.size);

        if (this.data == null) goto #error;

        for (b_8 int i = 0, i < this.size, i++) {
            this.data[i] = (i % 2 == 0) ? i : -i;
        }

        return;

        #error:
        this.size = 0;
    }

    b_8 int get(b_8 int index) {
        rt (index < this.size) ? this.data[index] : 0;
    }

    void dehydrate() {
        if (this.data != null) {
            free(this.data);
        }
    }
}

