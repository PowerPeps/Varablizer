// ==================================================

class Engine {
    void mount() {
        pf("mount");
    }

    void boot() {
        pf("boot");
    }

    void updated() {
        pf("updated");
    }
}

// ==================================================
// 37. ARROW LAMBDA
// ==================================================

() => {
    pf("arrow lambda");
}

// ==================================================
// 38. BLOCK LAMBDA SIMPLE
// ==================================================

adder := { rt $1 + $2 }>

// ==================================================
// 39. BLOCK LAMBDA AVEC CAPTURE
// ==================================================

result := [10, 5] ={ rt $1 + $2 }>

// ==================================================
// 40. LAMBDA COMPLEXE
// ==================================================

complex = {
    $1++;
    $2--;
    rt $1 * $2;
}>

